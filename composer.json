{
    "name": "baptiste-contreras/ez-deliver",
    "type": "project",
    "require": {
        "jolicode/castor": "^0.20.0",
        "php": "^8.4",
        "symfony/serializer": "^7.4",
        "symfony/property-access": "^7.4",
        "symfony/serializer-pack": "^1.3"
    },

    "authors": [
        {
            "name": "Baptiste CONTRERAS"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ezdeliver\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.66",
        "phpunit/phpunit": "^11"
    },
    "autoload-dev": {
        "psr-4": {
            "Ezdeliver\\Tests\\": "tests/"
        }
    }
}
